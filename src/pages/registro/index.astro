---
import RegisterForm from "../../components/registro/RegisterForm";
import Layout from "../../layouts/Layout.astro";
import { Navigation } from "../../types/navigation";
---

<Layout title="FindMi - Músicos" page={Navigation.CREATE}>
  <main
    class="w-screen height flex justify-center items-center flex-col text-center gap-10 px-10 bg-gradient-to-br from-orange-50 to-red-50 overflow-x-hidden py-32"
  >
    <RegisterForm client:load />
  </main>
  <style is:global>
    .form-section-style {
      @apply flex flex-col gap-6 relative;
      opacity: 0;
      animation: fadeInFromRight 0.5s ease-out both;
    }

    @keyframes fadeInFromRight {
      from {
        opacity: 0;
        transform: translateX(30%);
      }
      to {
        opacity: 1;
        transform: translateX(0);
      }
    }
  </style>
</Layout>
